from collections.abc import Callable

class ValidationError(Exception):
    # The structured, machine-readable error model. `errors` is a tuple of
    # per-failure items, each a JSON-serializable dict with the keys
    # `code`/`path`/`message`/`expected`/`value`; `json.dumps(err.errors)` is the
    # JSON output. The scalar attributes mirror the first item.
    code: str
    path: tuple[str | int, ...]
    message: str
    expected: str
    value: str
    errors: tuple[dict[str, object], ...]
    def __init__(self, message: str) -> None: ...

class CompiledValidator:
    def validate(self, obj: object, *, fail_fast: bool = ...) -> None: ...
    def is_valid(self, obj: object) -> bool: ...
    def ensure(self, obj: object) -> object: ...
    def validate_json(self, data: str | bytes, *, fail_fast: bool = ...) -> None: ...
    def is_valid_json(self, data: str | bytes) -> bool: ...
    def open(self) -> CompiledValidator: ...
    def close(self) -> CompiledValidator: ...
    def is_empty(self) -> bool: ...
    def is_subtype_of(self, other: object) -> bool: ...
    def is_equivalent(self, other: object) -> bool: ...

def validator(schema: object) -> CompiledValidator: ...
def union(*schemas: object) -> CompiledValidator: ...
def intersection(*schemas: object) -> CompiledValidator: ...
def complement(schema: object) -> CompiledValidator: ...
def fixed_sequence(*members: object) -> CompiledValidator: ...
def simplify(validator: CompiledValidator) -> CompiledValidator: ...
def recursive(
    builder: Callable[[CompiledValidator], object],
) -> CompiledValidator: ...

anything: CompiledValidator
nothing: CompiledValidator
